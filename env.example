# Pick an API model that is enabled for the relevant API projects/accounts.
# This shared model is used unless a player-specific override is set below.
MAFIA_MODEL=YOUR_MODEL_NAME

# Language of public game messages and GPT-player prompts.
# Supported: en (English), ko (Korean)
MAFIA_LANGUAGE=ko

# One independent API key per GPT player. Never put a real key in this file,
# and never commit your real .env file.
MAFIA_API_KEY_ARA=
MAFIA_API_KEY_BORA=
MAFIA_API_KEY_CHAE=
MAFIA_API_KEY_DURI=
MAFIA_API_KEY_EUN=
MAFIA_API_KEY_FAYE=
MAFIA_API_KEY_GARAM=

# Optional: use a different model for a particular player.
# MAFIA_MODEL_ARA=YOUR_OTHER_MODEL_NAME
